{
  "name": "quranic-corpus-api-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "copy-resources": "./scripts/copy-resources.sh",
    "build": "tsc -p tsconfig.build.json && npm run copy-resources",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepare-release": "./scripts/prepare-release.sh"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "fast-xml-parser": "^5.3.0",
    "fastify": "^5.6.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
